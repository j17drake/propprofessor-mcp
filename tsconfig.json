{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "noResolve": true
  },
  "include": ["lib/propprofessor-lru-cache.js", "lib/propprofessor-redact.js"]
}
