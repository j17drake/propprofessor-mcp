{
  "name": "propprofessor-mcp",
  "version": "1.0.7",
  "description": "Beginner-friendly PropProfessor MCP server and setup CLI for any MCP client",
  "type": "commonjs",
  "private": false,
  "main": "scripts/propprofessor-mcp-server.js",
  "exports": {
    ".": "./scripts/propprofessor-mcp-server.js",
    "./api": "./lib/propprofessor-api.js",
    "./analysis": "./lib/propprofessor-analysis.js",
    "./mcp-stdio": "./lib/propprofessor-mcp-stdio.js",
    "./ranked-screen": "./lib/propprofessor-mcp-ranked-screen.js",
    "./screen-utils": "./lib/propprofessor-screen-utils.js",
    "./sharp-books": "./lib/propprofessor-sharp-books.js",
    "./sharp-plays": "./lib/propprofessor-sharp-plays.js",
    "./sharp-plays-service": "./lib/propprofessor-sharp-plays-service.js"
  },
  "bin": {
    "pp-mcp": "scripts/propprofessor-mcp-server.js",
    "pp-query": "scripts/query-propprofessor.js"
  },
  "files": [
    "lib/",
    "scripts/",
    "README.md",
    "AUTH.md",
    "CONFIG.md",
    "MAINTAINERS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j17drake/propprofessor-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/j17drake/propprofessor-mcp/issues"
  },
  "homepage": "https://github.com/j17drake/propprofessor-mcp#readme",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "propprofessor",
    "sports-betting",
    "cli",
    "ai-agent"
  ],
  "author": "James Drake",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "mcp": "node scripts/propprofessor-mcp-server.js",
    "query": "node scripts/query-propprofessor.js",
    "export-screen": "node scripts/export-ranked-screen.js",
    "smoke:live": "node scripts/smoke-live.js",
    "check:version": "node scripts/check-version-consistency.js",
    "audit:sharp-research": "node scripts/audit-sharp-play-research.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "got-scraping": "^4.2.1",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^10.4.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.3"
  }
}
