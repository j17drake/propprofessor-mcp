{
  "name": "propprofessor-mcp",
  "version": "2.5.0",
  "description": "Beginner-friendly PropProfessor MCP server and setup CLI for any MCP client",
  "type": "commonjs",
  "private": true,
  "main": "scripts/propprofessor-mcp-server.js",
  "exports": {
    ".": "./scripts/propprofessor-mcp-server.js",
    "./api": "./lib/propprofessor-api.js",
    "./auth": "./lib/propprofessor-auth.js",
    "./analysis": "./lib/propprofessor-analysis.js",
    "./mcp-stdio": "./lib/propprofessor-mcp-stdio.js",
    "./ranked-screen": "./lib/propprofessor-mcp-ranked-screen.js",
    "./screen-parser": "./lib/screen-parser.js",
    "./selection-resolver": "./lib/selection-resolver.js",
    "./screen-ranker": "./lib/screen-ranker.js",
    "./league-presets": "./lib/league-presets.js",
    "./screen-summary": "./lib/screen-summary.js",
    "./screen-tennis": "./lib/screen-tennis.js",
    "./sharp-books": "./lib/propprofessor-sharp-books.js",
    "./sharp-plays": "./lib/propprofessor-sharp-plays.js",
    "./sharp-plays-service": "./lib/propprofessor-sharp-plays-service.js"
  },
  "bin": {
    "pp-mcp": "scripts/propprofessor-mcp-server.js",
    "pp-query": "scripts/query-propprofessor.js",
    "pp": "bin/pp"
  },
  "files": [
    "lib/",
    "scripts/",
    "config.default.json",
    "README.md",
    "INSTALL.md",
    "CONFIG.md",
    "MAINTAINERS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j17drake/propprofessor-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/j17drake/propprofessor-mcp/issues"
  },
  "homepage": "https://github.com/j17drake/propprofessor-mcp#readme",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "propprofessor",
    "sports-betting",
    "cli",
    "ai-agent"
  ],
  "author": "James Drake",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "mcp": "node scripts/propprofessor-mcp-server.js",
    "query": "node scripts/query-propprofessor.js",
    "export-screen": "node scripts/export-ranked-screen.js",
    "exe": "node scripts/prop-professor.exe.js",
    "check:version": "node scripts/check-version-consistency.js",
    "check:claims": "node scripts/check-claims.js",
    "check:claims:quick": "node scripts/check-claims.js --quick",
    "check:secrets": "node scripts/check-no-secrets.js",
    "precommit:secrets": "node scripts/check-no-secrets.js --working-tree-only",
    "check:types": "tsc",
    "check:circular": "madge --circular --warning lib/ scripts/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:openapi": "node scripts/generate-openapi-spec.js > docs/openapi.json",
    "test": "node --test test/*.test.js",
    "test:coverage": "c8 --reporter=text-summary --reporter=lcov node --test test/*.test.js"
  },
  "dependencies": {
    "got-scraping": "^4.2.1"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0"
  },
  "c8": {
    "all": true,
    "include": [
      "lib/",
      "scripts/"
    ],
    "exclude": [
      "test/",
      "node_modules/",
      "coverage/"
    ],
    "reporter": [
      "text-summary",
      "lcov"
    ],
    "branches": 60,
    "functions": 70,
    "lines": 70,
    "statements": 70
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-complexity": "^1.0.2",
    "globals": "^17.6.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}
